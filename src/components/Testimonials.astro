---

<section class="py-24 bg-[#f8f8f8] overflow-hidden">
  <div class="max-w-6xl mx-auto px-5">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="reveal inline-flex items-center gap-2 bg-[#37c760]/10 text-[#37c760] text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded-full mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#37c760" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Trustpilot anmeldelser
      </div>
      <h2 class="reveal reveal-delay-1 text-4xl md:text-5xl font-extrabold text-[#0a112d] mb-3">
        Hvad kunderne siger
      </h2>
      <p class="reveal reveal-delay-2 text-[#5a6a7e] text-lg max-w-xl mx-auto">
        Alle anmeldelser er uopfordrede og hentet direkte fra Trustpilot.
      </p>
    </div>

    <!-- Karussel -->
    <div class="relative">
      <div class="absolute left-0 top-0 bottom-0 w-16 bg-gradient-to-r from-[#f8f8f8] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 bg-gradient-to-l from-[#f8f8f8] to-transparent z-10 pointer-events-none"></div>

      <div id="tp-track" class="flex gap-6" style="transition: transform 0.5s cubic-bezier(.4,0,.2,1); will-change: transform;">
        {reviews.map((r) => (
          <div class="flex-shrink-0 w-[340px] bg-white rounded-2xl p-7 border border-[#e2e8f0] flex flex-col shadow-sm">
            <!-- Stjerner -->
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#37c760" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <!-- Tekst -->
            <p class="text-[#2a2a2a] text-[14px] leading-relaxed flex-1 mb-5">{r.text}</p>
            <!-- Person -->
            <div class="flex items-center gap-3 pt-4 border-t border-[#f1f5f9]">
              {r.image
                ? <img src={r.image} alt={r.name} class="w-10 h-10 rounded-full object-cover shrink-0" />
                : <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold shrink-0" style={`background:${r.color}; color:${r.color === '#bfd0e0' ? '#0a112d' : '#fff'};`}>{r.initials}</div>
              }
              <div>
                <div class="font-semibold text-[#0a112d] text-sm">{r.name}</div>
                <div class="text-[#5a6a7e] text-xs">{r.company ? r.company + ' · ' : ''}{r.date}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex items-center justify-center gap-6 mt-10">
      <button id="tp-prev" aria-label="Forrige" class="w-10 h-10 rounded-full border-2 border-[#e2e8f0] flex items-center justify-center text-[#0a112d] hover:border-[#37c760] hover:text-[#37c760] transition-colors duration-200">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="flex gap-2">
        {reviews.map((_, i) => (
          <button
            class="tp-dot rounded-full transition-all duration-300"
            data-index={String(i)}
            aria-label={`Anmeldelse ${i + 1}`}
            style={i === 0 ? 'background:#37c760;width:1.5rem;height:0.5rem;' : 'background:#e2e8f0;width:0.5rem;height:0.5rem;'}
          ></button>
        ))}
      </div>
      <button id="tp-next" aria-label="Næste" class="w-10 h-10 rounded-full border-2 border-[#e2e8f0] flex items-center justify-center text-[#0a112d] hover:border-[#37c760] hover:text-[#37c760] transition-colors duration-200">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

  </div>
</section>

<script>
  const track = document.getElementById('tp-track') as HTMLElement;
  const dots = document.querySelectorAll<HTMLElement>('.tp-dot');
  const TOTAL = 8;
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  const getVisible = () => window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
  const cardW = () => (track.firstElementChild as HTMLElement)?.offsetWidth + 24 || 364;

  function goTo(n: number) {
    const max = TOTAL - getVisible();
    current = Math.max(0, Math.min(((n % TOTAL) + TOTAL) % TOTAL, max));
    track.style.transform = `translateX(-${current * cardW()}px)`;
    dots.forEach((d, i) => {
      d.style.background = i === current ? '#37c760' : '#e2e8f0';
      d.style.width = i === current ? '1.5rem' : '0.5rem';
    });
  }

  const next = () => goTo(current + 1 > TOTAL - getVisible() ? 0 : current + 1);
  const prev = () => goTo(current - 1 < 0 ? TOTAL - getVisible() : current - 1);
  const resetAuto = () => { clearInterval(timer); timer = setInterval(next, 4000); };

  document.getElementById('tp-next')?.addEventListener('click', () => { next(); resetAuto(); });
  document.getElementById('tp-prev')?.addEventListener('click', () => { prev(); resetAuto(); });
  dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); resetAuto(); }));
  window.addEventListener('resize', () => goTo(current));

  timer = setInterval(next, 4000);
</script>
